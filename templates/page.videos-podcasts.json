    "custom_liquid_LdTQyQ": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.presets.name",
      "settings": {
        "custom_liquid": "<script>\n/**\n * Yottie YouTube Widget — Tab Accessibility Fix\n * ===============================================\n * Fixes the nav <a role=\"button\"> elements so they behave as\n * proper ARIA tabs (role=\"tab\" / role=\"tablist\" / role=\"tabpanel\").\n *\n * ISSUES FIXED:\n *  1. <a role=\"button\"> → role=\"tab\"  (wrong role; AT reads \"button\" not \"tab\")\n *  2. <ul> has no role=\"tablist\" or accessible label\n *  3. No aria-selected to communicate active tab to AT\n *  4. Active state only in CSS class (yottie-active) — invisible to AT\n *  5. Tabs have no id, panels have no role=\"tabpanel\" or aria-labelledby\n *  6. No aria-controls linking tab → panel\n *  7. Tab key should move OUT of tablist; arrow keys navigate WITHIN it (ARIA pattern)\n *  8. Nav scroll controls have no accessible label\n *\n * INSTALL (Shopify):\n *   Upload file → add before </body> in theme.liquid:\n *   <script src=\"{{ 'yottie-a11y-fix.js' | asset_url }}\" defer></script>\n *\n *   OR paste contents inside a <script> tag before </body>.\n */\n\n(function () {\n  'use strict';\n\n  var uidCounter = 0;\n  function uid(prefix) { return (prefix || 'yottie-a11y') + '-' + (++uidCounter); }\n\n  /* ─── Fix one complete Yottie widget ──────────────────────────────────── */\n  function fixWidget(widget) {\n\n    var navList   = widget.querySelector('.yottie-widget-nav-list');\n    var tabLinks  = navList ? Array.prototype.slice.call(\n                      navList.querySelectorAll('a[data-yt-id]')) : [];\n    var sections  = Array.prototype.slice.call(\n                      widget.querySelectorAll('.yottie-widget-feed-section'));\n\n    if (!navList || !tabLinks.length) { return; }\n\n    /* 1 ── <ul> becomes role=\"tablist\" */\n    navList.setAttribute('role', 'tablist');\n    navList.setAttribute('aria-label', 'Video categories');\n\n    /* 2 ── <li> wrappers must NOT have a meaningful role inside a tablist */\n    Array.prototype.slice.call(navList.querySelectorAll('li')).forEach(function (li) {\n      li.setAttribute('role', 'presentation');   // removes list-item semantics per ARIA spec\n    });\n\n    /* 3 ── Fix each tab <a> */\n    tabLinks.forEach(function (tab, i) {\n      var tabId   = uid('yottie-tab');\n      var panelId = uid('yottie-panel');\n\n      tab.id = tabId;\n      tab.setAttribute('role', 'tab');\n      tab.removeAttribute('href');              // bare <a> with no href shouldn't navigate\n\n      var isActive = tab.closest('li').classList.contains('yottie-active')\n                  || tab.closest('li').classList.contains('yottie-active');\n      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');\n      tab.setAttribute('tabindex',      isActive ? '0'    : '-1');\n      tab.setAttribute('aria-controls', panelId);\n\n      /* 4 ── Wire the matching feed section as a tabpanel */\n      var panel = sections[i];\n      if (panel) {\n        panel.id = panelId;\n        panel.setAttribute('role', 'tabpanel');\n        panel.setAttribute('aria-labelledby', tabId);\n        // Hidden panels should be inert to AT\n        panel.setAttribute('tabindex', '0');    // panel itself is focusable (ARIA best practice)\n        if (!isActive) {\n          panel.setAttribute('aria-hidden', 'true');\n        } else {\n          panel.removeAttribute('aria-hidden');\n        }\n      }\n    });\n\n    /* 5 ── Keyboard: arrow-key navigation within tablist (ARIA tabs pattern)\n            Tab key moves focus OUT of the tablist entirely               */\n    navList.addEventListener('keydown', function (e) {\n      var focused = document.activeElement;\n      if (!focused || focused.getAttribute('role') !== 'tab') { return; }\n\n      var currentIndex = tabLinks.indexOf(focused);\n      var nextIndex = -1;\n\n      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {\n        e.preventDefault();\n        nextIndex = (currentIndex + 1) % tabLinks.length;\n      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n        e.preventDefault();\n        nextIndex = (currentIndex - 1 + tabLinks.length) % tabLinks.length;\n      } else if (e.key === 'Home') {\n        e.preventDefault();\n        nextIndex = 0;\n      } else if (e.key === 'End') {\n        e.preventDefault();\n        nextIndex = tabLinks.length - 1;\n      } else if (e.key === 'Enter' || e.key === ' ') {\n        e.preventDefault();\n        focused.click();\n        return;\n      }\n\n      if (nextIndex >= 0) {\n        tabLinks[nextIndex].focus();\n        // Activate on focus (automatic activation pattern — common for non-loading tabs)\n        tabLinks[nextIndex].click();\n      }\n    });\n\n    /* 6 ── Sync aria-selected + aria-hidden when Yottie activates a tab\n            (Yottie toggles yottie-active class on <li> and show/hides sections) */\n    var observer = new MutationObserver(function () {\n      tabLinks.forEach(function (tab, i) {\n        var isNowActive = tab.closest('li').classList.contains('yottie-active');\n        tab.setAttribute('aria-selected', isNowActive ? 'true' : 'false');\n        tab.setAttribute('tabindex',      isNowActive ? '0'    : '-1');\n\n        var panel = sections[i];\n        if (panel) {\n          if (isNowActive) {\n            panel.removeAttribute('aria-hidden');\n          } else {\n            panel.setAttribute('aria-hidden', 'true');\n          }\n        }\n      });\n    });\n\n    Array.prototype.slice.call(navList.querySelectorAll('li')).forEach(function (li) {\n      observer.observe(li, { attributes: true, attributeFilter: ['class'] });\n    });\n\n    /* 7 ── Nav scroll controls: give the empty <span> buttons an accessible label */\n    var leftCtrl  = widget.querySelector('.yottie-widget-nav-control-left');\n    var rightCtrl = widget.querySelector('.yottie-widget-nav-control-right');\n\n    if (leftCtrl) {\n      leftCtrl.setAttribute('role', 'button');\n      leftCtrl.setAttribute('tabindex', leftCtrl.classList.contains('yottie-widget-nav-control-disabled') ? '-1' : '0');\n      leftCtrl.setAttribute('aria-label', 'Scroll categories left');\n      leftCtrl.setAttribute('aria-disabled',\n        leftCtrl.classList.contains('yottie-widget-nav-control-disabled') ? 'true' : 'false');\n    }\n    if (rightCtrl) {\n      rightCtrl.setAttribute('role', 'button');\n      rightCtrl.setAttribute('tabindex', rightCtrl.classList.contains('yottie-widget-nav-control-disabled') ? '-1' : '0');\n      rightCtrl.setAttribute('aria-label', 'Scroll categories right');\n      rightCtrl.setAttribute('aria-disabled',\n        rightCtrl.classList.contains('yottie-widget-nav-control-disabled') ? 'true' : 'false');\n      // Keep aria-disabled in sync\n      new MutationObserver(function () {\n        var disabled = rightCtrl.classList.contains('yottie-widget-nav-control-disabled');\n        rightCtrl.setAttribute('aria-disabled', disabled ? 'true' : 'false');\n        rightCtrl.setAttribute('tabindex', disabled ? '-1' : '0');\n      }).observe(rightCtrl, { attributes: true, attributeFilter: ['class'] });\n    }\n  }\n\n  /* ─── Watch for Yottie widgets injected into the page ─────────────────── */\n  function init() {\n    document.querySelectorAll('.yottie-widget-contents').forEach(function (w) {\n      if (!w.dataset.yottieA11yFixed) {\n        w.dataset.yottieA11yFixed = '1';\n        fixWidget(w);\n      }\n    });\n\n    // Re-run if Yottie injects widgets dynamically\n    new MutationObserver(function () {\n      document.querySelectorAll('.yottie-widget-contents').forEach(function (w) {\n        if (!w.dataset.yottieA11yFixed) {\n          w.dataset.yottieA11yFixed = '1';\n          fixWidget(w);\n        }\n      });\n    }).observe(document.body, { childList: true, subtree: true });\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n\n}());\n</script>",
        "divider_style": "none",
        "section_padding": "section--vertical-padding-top-bottom"
      }
    }
