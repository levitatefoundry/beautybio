    "custom_liquid_LdTQyQ": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.presets.name",
      "settings": {
        "custom_liquid": "<script>\n/**\n * Yottie YouTube Widget — Tab Accessibility Fix v2\n * ==================================================\n * More robust version that handles:\n *  - Yottie loading its DOM asynchronously (after DOMContentLoaded)\n *  - Script running before widget HTML exists\n *  - Yottie re-rendering on tab switch\n *\n * FIXES APPLIED:\n *  1. <a role=\"button\"> → role=\"tab\"\n *  2. <ul> → role=\"tablist\" aria-label=\"Video categories\"\n *  3. <li> → role=\"presentation\"\n *  4. aria-selected synced from yottie-active class\n *  5. tabindex roving (0 on active, -1 on rest) — correct tab pattern\n *  6. Feed sections get role=\"tabpanel\" + aria-labelledby pointing to their tab\n *  7. aria-hidden on inactive panels\n *  8. Nav scroll arrow controls get role=\"button\" + aria-label + aria-disabled\n *  9. Keyboard: ArrowLeft/Right navigate tabs; Tab exits tablist\n * 10. MutationObserver keeps everything in sync after Yottie updates classes\n * 11. Polling fallback in case widget loads very late\n *\n * INSTALL:\n *  Paste this entire script inside a <script> tag just before </body> in theme.liquid\n *  This is more reliable than an external deferred file for async 3rd-party widgets.\n */\n\n(function () {\n  'use strict';\n\n  var uidCounter = 0;\n  function uid(prefix) { return (prefix || 'ya') + (++uidCounter); }\n\n  /* ── Sync tab + panel states from current DOM classes ─────────────────── */\n  function syncStates(tabLinks, sections) {\n    tabLinks.forEach(function (tab, i) {\n      var li        = tab.parentElement;\n      var isActive  = li && li.classList.contains('yottie-active');\n\n      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');\n      tab.setAttribute('tabindex',      isActive ? '0'    : '-1');\n\n      var panel = sections[i];\n      if (panel) {\n        if (isActive) {\n          panel.removeAttribute('aria-hidden');\n        } else {\n          panel.setAttribute('aria-hidden', 'true');\n        }\n      }\n    });\n  }\n\n  /* ── Fix one widget ────────────────────────────────────────────────────── */\n  function fixWidget(widget) {\n    var navList  = widget.querySelector('.yottie-widget-nav-list');\n    if (!navList) { return false; }   // not ready yet\n\n    var tabLinks = Array.prototype.slice.call(navList.querySelectorAll('a[data-yt-id]'));\n    if (!tabLinks.length) { return false; }\n\n    var sections = Array.prototype.slice.call(\n                     widget.querySelectorAll('.yottie-widget-feed-section'));\n\n    /* already fixed — just re-sync states in case Yottie re-rendered */\n    if (navList.getAttribute('role') === 'tablist') {\n      syncStates(tabLinks, sections);\n      return true;\n    }\n\n    /* ── tablist ── */\n    navList.setAttribute('role', 'tablist');\n    navList.setAttribute('aria-label', 'Video categories');\n\n    /* ── list items: presentation (required inside tablist per ARIA spec) ── */\n    Array.prototype.slice.call(navList.querySelectorAll('li')).forEach(function (li) {\n      li.setAttribute('role', 'presentation');\n    });\n\n    /* ── individual tabs ── */\n    tabLinks.forEach(function (tab, i) {\n      var tabId   = tab.id   || uid('ytab');\n      var panelId = uid('ypanel');\n\n      tab.id = tabId;\n      tab.setAttribute('role', 'tab');\n\n      /* <a> without href should not behave as a link */\n      if (!tab.getAttribute('href')) {\n        tab.setAttribute('href', '#');\n        tab.addEventListener('click', function (e) { e.preventDefault(); });\n      }\n\n      tab.setAttribute('aria-controls', panelId);\n\n      /* ── tabpanel ── */\n      var panel = sections[i];\n      if (panel) {\n        panel.id = panelId;\n        panel.setAttribute('role', 'tabpanel');\n        panel.setAttribute('aria-labelledby', tabId);\n        panel.setAttribute('tabindex', '0');\n      }\n    });\n\n    /* ── initial state sync ── */\n    syncStates(tabLinks, sections);\n\n    /* ── keyboard: roving tabindex + arrow navigation ── */\n    navList.addEventListener('keydown', function (e) {\n      var focused = document.activeElement;\n      if (!focused || focused.getAttribute('role') !== 'tab') { return; }\n\n      var idx  = tabLinks.indexOf(focused);\n      var next = -1;\n\n      switch (e.key) {\n        case 'ArrowRight':\n        case 'ArrowDown':\n          e.preventDefault();\n          next = (idx + 1) % tabLinks.length;\n          break;\n        case 'ArrowLeft':\n        case 'ArrowUp':\n          e.preventDefault();\n          next = (idx - 1 + tabLinks.length) % tabLinks.length;\n          break;\n        case 'Home':\n          e.preventDefault();\n          next = 0;\n          break;\n        case 'End':\n          e.preventDefault();\n          next = tabLinks.length - 1;\n          break;\n        case 'Enter':\n        case ' ':\n          e.preventDefault();\n          focused.click();\n          return;\n      }\n\n      if (next >= 0) {\n        tabLinks[next].focus();\n        tabLinks[next].click();\n      }\n    });\n\n    /* ── observe class changes on <li>s to keep aria-selected in sync ── */\n    Array.prototype.slice.call(navList.querySelectorAll('li')).forEach(function (li) {\n      new MutationObserver(function () {\n        syncStates(tabLinks, sections);\n      }).observe(li, { attributes: true, attributeFilter: ['class'] });\n    });\n\n    /* ── nav scroll controls ── */\n    fixNavControls(widget);\n\n    return true;\n  }\n\n  /* ── Fix scroll arrow controls ────────────────────────────────────────── */\n  function fixNavControls(widget) {\n    [\n      { sel: '.yottie-widget-nav-control-left',  label: 'Scroll categories left'  },\n      { sel: '.yottie-widget-nav-control-right', label: 'Scroll categories right' }\n    ].forEach(function (cfg) {\n      var el = widget.querySelector(cfg.sel);\n      if (!el) { return; }\n\n      if (!el.getAttribute('role')) { el.setAttribute('role', 'button'); }\n      el.setAttribute('aria-label', cfg.label);\n\n      function updateDisabled() {\n        var dis = el.classList.contains('yottie-widget-nav-control-disabled');\n        el.setAttribute('aria-disabled', dis ? 'true' : 'false');\n        el.setAttribute('tabindex',      dis ? '-1'   : '0');\n      }\n      updateDisabled();\n\n      new MutationObserver(updateDisabled)\n        .observe(el, { attributes: true, attributeFilter: ['class'] });\n\n      /* Enter/Space activate for keyboard users */\n      el.addEventListener('keydown', function (e) {\n        if (e.key === 'Enter' || e.key === ' ') {\n          e.preventDefault();\n          el.click();\n        }\n      });\n    });\n  }\n\n  /* ── Find and fix all widgets on the page ─────────────────────────────── */\n  function fixAll() {\n    document.querySelectorAll('.yottie-widget-contents').forEach(function (w) {\n      fixWidget(w);\n    });\n  }\n\n  /* ── Poll until Yottie renders, then hand off to MutationObserver ─────── */\n  function waitAndFix() {\n    var maxAttempts = 40;   // 40 × 250ms = 10 seconds max\n    var attempts    = 0;\n    var found       = false;\n\n    var poll = setInterval(function () {\n      attempts++;\n      var widgets = document.querySelectorAll('.yottie-widget-contents');\n\n      widgets.forEach(function (w) {\n        if (!w.dataset.yottieA11y) {\n          var ok = fixWidget(w);\n          if (ok) { w.dataset.yottieA11y = '1'; found = true; }\n        }\n      });\n\n      /* once found, stop polling and rely on MutationObserver */\n      if (found || attempts >= maxAttempts) {\n        clearInterval(poll);\n      }\n    }, 250);\n\n    /* MutationObserver catches widgets injected even later */\n    new MutationObserver(function () {\n      document.querySelectorAll('.yottie-widget-contents').forEach(function (w) {\n        if (!w.dataset.yottieA11y) {\n          var ok = fixWidget(w);\n          if (ok) { w.dataset.yottieA11y = '1'; }\n        }\n        /* also re-sync if Yottie re-renders nav internals */\n        if (w.dataset.yottieA11y) { fixWidget(w); }\n      });\n    }).observe(document.body, { childList: true, subtree: true });\n  }\n\n  /* ── Boot ─────────────────────────────────────────────────────────────── */\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', waitAndFix);\n  } else {\n    waitAndFix();\n  }\n\n}());\n</script>",
        "divider_style": "none",
        "section_padding": "section--vertical-padding-top-bottom"
      }
    }
