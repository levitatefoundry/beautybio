      "settings": {
        "custom_liquid": "<script>\n(function() {\n  let checkCount = 0;\n  const maxChecks = 60; // Stop after 30 seconds (60 * 500ms)\n  \n  function addAriaLabel() {\n    const closeButton = document.querySelector('.oct-quiz-close');\n    \n    if (closeButton && !closeButton.hasAttribute('aria-label')) {\n      closeButton.setAttribute('aria-label', 'Close quiz');\n      return true;\n    }\n    return false;\n  }\n  \n  // Try immediately\n  if (addAriaLabel()) return;\n  \n  // Set up interval checking\n  const checkInterval = setInterval(() => {\n    checkCount++;\n    \n    if (addAriaLabel() || checkCount >= maxChecks) {\n      clearInterval(checkInterval);\n    }\n  }, 500);\n  \n  // Also use MutationObserver for instant detection\n  const observer = new MutationObserver(() => {\n    if (addAriaLabel()) {\n      // Keep observer running in case quiz closes and reopens\n    }\n  });\n  \n  observer.observe(document.body, {\n    childList: true,\n    subtree: true\n  });\n})();\n</script>\n<script>\n/**\n * Octane AI Quiz — Accessibility Fix v2\n * ======================================\n * Fixes identified in the live embed HTML:\n *\n *  ISSUE 1 — Conflicting labels on <li> radio items\n *    · title=\"Dry\" but visible text = \"Aging\"  → AT reads wrong label\n *    · Inner image div has role=\"img\" aria-label=\"Oily\" (old internal key)\n *      conflicting with visible text \"Blemish Prone\"\n *    FIX: Strip title + silence the image div; derive single aria-label\n *         exclusively from the visible text node.\n *\n *  ISSUE 2 — role=\"heading\" aria-level=\"1\" not associated with radiogroup\n *    · Heading and <ul> are sibling divs with no programmatic link.\n *      Screen reader announces the group with no question context.\n *    FIX: Generate a unique id for the heading, then set\n *         aria-labelledby on the <ul> pointing to that id.\n *\n *  ISSUE 3 — <li> items lack role=\"radio\" + aria-checked\n *    · Rendered as plain list items; AT cannot infer selection state.\n *    FIX: role=\"radio\", aria-checked kept in sync via MutationObserver.\n *\n *  ISSUE 4 — No keyboard radio-group navigation\n *    FIX: Arrow keys move focus; Enter/Space trigger click.\n *\n *  ISSUE 5 — No live announcement on selection\n *    FIX: aria-live=\"polite\" region announces chosen label.\n *\n *  ISSUE 6 — Multi-step quiz replaces DOM; fixes must re-apply\n *    FIX: MutationObserver on <body> re-runs on every new wrapper.\n *\n * HOW TO INSTALL (Shopify)\n * -------------------------\n *  Option A — theme.liquid (recommended):\n *    1. Upload this file to Shopify → Content → Files\n *    2. Add before </body>:\n *       <script src=\"{{ 'octane-quiz-a11y-fix-v2.js' | asset_url }}\" defer></script>\n *\n *  Option B — inline:\n *    Paste the entire script inside a <script> tag before </body>.\n */\n\n(function () {\n  'use strict';\n\n  /* ─── Unique ID counter ─────────────────────────────────────────────────── */\n  var uidCounter = 0;\n  function uid(prefix) {\n    return (prefix || 'oct-a11y') + '-' + (++uidCounter);\n  }\n\n  /* ─── Single polite live region ─────────────────────────────────────────── */\n  function getLiveRegion() {\n    var id = 'oct-a11y-live';\n    var el = document.getElementById(id);\n    if (!el) {\n      el = document.createElement('div');\n      el.id = id;\n      el.setAttribute('role', 'status');\n      el.setAttribute('aria-live', 'polite');\n      el.setAttribute('aria-atomic', 'true');\n      el.style.cssText =\n        'position:absolute;width:1px;height:1px;padding:0;' +\n        'margin:-1px;overflow:hidden;clip:rect(0,0,0,0);' +\n        'white-space:nowrap;border:0;';\n      document.body.appendChild(el);\n    }\n    return el;\n  }\n\n  function announce(msg) {\n    var live = getLiveRegion();\n    live.textContent = '';\n    requestAnimationFrame(function () { live.textContent = msg; });\n  }\n\n  /* ─── Read the ONE trustworthy label: the visible text node ─────────────── */\n  function getVisibleLabel(li) {\n    /*\n     * Octane renders three child divs inside each <li>:\n     *   [0] decorative image div  (role=\"img\" aria-label= internal key — WRONG)\n     *   [1] visible text label    ← the only source of truth\n     *   [2] empty spacer div\n     *\n     * We target the second div directly. Fall back to title only if empty.\n     */\n    var children = li.children;\n    var labelText = '';\n\n    for (var i = 0; i < children.length; i++) {\n      var child = children[i];\n      // Skip the image div and empty divs; grab the first non-empty text div\n      if (!child.hasAttribute('role') && child.textContent.trim()) {\n        labelText = child.textContent.trim();\n        break;\n      }\n    }\n\n    // Final fallback (should not be needed)\n    if (!labelText) {\n      labelText = li.getAttribute('title') || 'Option ' + (li.dataset.optionIndex || '');\n    }\n\n    return labelText;\n  }\n\n  /* ─── Fix one quiz wrapper ───────────────────────────────────────────────── */\n  function fixWrapper(wrapper) {\n\n    /* 1 ── Heading: ensure it has a stable id so we can reference it */\n    var heading = wrapper.querySelector('[data-element~=\"oct-quiz-title\"]');\n    if (heading) {\n      if (!heading.id) { heading.id = uid('oct-quiz-heading'); }\n      // Octane sometimes sets aria-level=\"1\" — demote to 2 inside page context\n      if (heading.getAttribute('aria-level') === '1') {\n        heading.setAttribute('aria-level', '2');\n      }\n      // Remove any stray aria-hidden on the heading\n      heading.removeAttribute('aria-hidden');\n    }\n\n    /* 2 ── Answer list: add radiogroup + link to heading via aria-labelledby */\n    var list = wrapper.querySelector('ul[id^=\"oct-multiple-choice-answers-root\"]');\n    if (!list) { return; }\n\n    list.setAttribute('role', 'radiogroup');\n    if (heading && heading.id) {\n      list.setAttribute('aria-labelledby', heading.id);\n    }\n\n    /* 3 ── Each answer <li> */\n    var options = Array.prototype.slice.call(list.querySelectorAll('li[data-option-id]'));\n\n    options.forEach(function (li) {\n\n      /* 3a — Derive single correct label from visible text */\n      var label = getVisibleLabel(li);\n\n      /* 3b — Strip conflicting attributes */\n      li.removeAttribute('title');          // \"Dry\" when text says \"Aging\" etc.\n\n      /* 3c — Set correct radio semantics with clean single label */\n      li.setAttribute('role', 'radio');\n      li.setAttribute('aria-label', label);\n\n      var isSelected =\n        li.getAttribute('data-is-option-selected') === 'selected' ||\n        li.classList.contains('oct-quiz-picture-choice-options__option--selected');\n      li.setAttribute('aria-checked', isSelected ? 'true' : 'false');\n\n      /* 3d — Silence the image div completely (it holds stale internal keys) */\n      var imgDiv = li.querySelector('[role=\"img\"]');\n      if (imgDiv) {\n        imgDiv.setAttribute('aria-hidden', 'true');\n        imgDiv.removeAttribute('role');\n        imgDiv.removeAttribute('aria-label');\n      }\n\n      /* 3e — Also silence the empty spacer div if present */\n      var allDivs = li.querySelectorAll('div');\n      allDivs.forEach(function (d) {\n        if (!d.textContent.trim() && !d.querySelector('img')) {\n          d.setAttribute('aria-hidden', 'true');\n        }\n      });\n\n      /* 3f — Keyboard behaviour (radio group pattern) */\n      li.removeEventListener('keydown', li._octA11yKeydown || null);\n      li._octA11yKeydown = function (e) {\n        if (e.key === 'Enter' || e.key === ' ') {\n          e.preventDefault();\n          li.click();\n        }\n        if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {\n          e.preventDefault();\n          var next = li.nextElementSibling;\n          if (next) { next.focus(); }\n        }\n        if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {\n          e.preventDefault();\n          var prev = li.previousElementSibling;\n          if (prev) { prev.focus(); }\n        }\n      };\n      li.addEventListener('keydown', li._octA11yKeydown);\n    });\n\n    /* 4 ── MutationObserver: keep aria-checked in sync after Octane updates */\n    if (list._octObserver) { list._octObserver.disconnect(); }\n\n    list._octObserver = new MutationObserver(function (mutations) {\n      mutations.forEach(function (m) {\n        var target = m.target;\n\n        // New <li> injected (next quiz step rendered into same list)\n        if (m.type === 'childList') {\n          m.addedNodes.forEach(function (node) {\n            if (node.nodeType === 1 && node.hasAttribute('data-option-id')) {\n              fixWrapper(wrapper);   // re-run full fix for the new step\n            }\n          });\n          return;\n        }\n\n        // Attribute change on existing <li>\n        if (!target.hasAttribute('data-option-id')) { return; }\n\n        var nowSelected =\n          target.getAttribute('data-is-option-selected') === 'selected' ||\n          target.classList.contains('oct-quiz-picture-choice-options__option--selected');\n\n        target.setAttribute('aria-checked', nowSelected ? 'true' : 'false');\n\n        if (nowSelected) {\n          var selectedLabel = target.getAttribute('aria-label') || 'option';\n          announce(selectedLabel + ' selected');\n        }\n      });\n    });\n\n    list._octObserver.observe(list, {\n      childList: true,\n      subtree: false,\n      attributes: true,\n      attributeFilter: ['data-is-option-selected', 'class'],\n    });\n  }\n\n  /* ─── Watch <body> for Octane injecting new question wrappers ───────────── */\n  function watchForNewWrappers() {\n    var bodyObserver = new MutationObserver(function () {\n      var wrappers = document.querySelectorAll('[id^=\"octane-question-wrapper\"]');\n      wrappers.forEach(function (w) {\n        if (!w.dataset.octA11yFixed) {\n          w.dataset.octA11yFixed = '1';\n          fixWrapper(w);\n        }\n      });\n    });\n    bodyObserver.observe(document.body, { childList: true, subtree: true });\n  }\n\n  /* ─── Init ───────────────────────────────────────────────────────────────── */\n  function init() {\n    document.querySelectorAll('[id^=\"octane-question-wrapper\"]').forEach(function (w) {\n      w.dataset.octA11yFixed = '1';\n      fixWrapper(w);\n    });\n    watchForNewWrappers();\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n\n}());\n</script>",
